# 360ghar Stays - Environment Configuration
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in the values

# =============================================================================
# REQUIRED VARIABLES - App will fail to start if these are missing
# =============================================================================

# Backend API endpoint
API_BASE_URL=https://api.your-domain.com

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Analytics (defaults to false for dev/staging, true for prod)
ENABLE_ANALYTICS=false

# Google Maps/Places API Key (for location features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Alternatively use GOOGLE_PLACES_API_KEY
# GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Google Sign-In (native ID-token flow). Wire when mobile Google lands.
# GOOGLE_WEB_CLIENT_ID is used as the Android serverClientId; GOOGLE_IOS_CLIENT_ID
# is used as the iOS clientId (and its reversed form for the iOS URL scheme).
# GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# Override the Google OAuth redirect deep link URL.
# Default: stays360://login-callback
# AUTH_REDIRECT_URL=
