# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
/build/
/ios/build/
/macos/Flutter/ephemeral/
/linux/flutter/ephemeral/
/windows/flutter/ephemeral/
/coverage/
.flutter-version

# Generated code (build_runner)
*.g.dart
*.freezed.dart
*.mocks.dart

# iOS
ios/Pods/
ios/.symlinks/
ios/Podfile.lock
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.xcworkspace/xcuserdata/

# Android
/android/.gradle
/android/captures
/android/local.properties
**/android/**/GeneratedPluginRegistrant.java

# macOS
macos/Pods/
macos/Podfile.lock
**/macos/**/*.xcworkspace/xcuserdata/

# Web
/web/favicon.png

# FVM (Flutter Version Manager)
.fvm/
.fvmrc

# Miscellaneous build/tool artifacts
.metadata
.packages
plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing keys - NEVER commit these
android/key.properties
android/*.keystore
android/*.jks
android/keystores/

# Env files
.env
.env.*
!.env.example

# Local developer tools/config that should not be committed
.claude/
.coderabbit_uncommitted_review.txt
.coderabbit/
